      "Bash(npm run *)",
      "Bash(bun run *)",
      "Bash(bun install*)",
      "Bash(npm install*)",
      "Bash(npx *)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git checkout*)",
      "Bash(git stash*)"
    ]
  }
}
