# =============================================================================
# imob-creator-studio — Environment Variables Template
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (REQUIRED — app fails to connect without these)
# Source: Supabase Dashboard → Project Settings → API
# Prefix MUST be VITE_ — Vite only exposes VITE_* to the browser bundle.
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<anon-public-key>

# Optional: used for local Supabase CLI tooling only (not read by frontend code)
# VITE_SUPABASE_PROJECT_ID=<project-ref>

# -----------------------------------------------------------------------------
# Analytics & Tracking (OPTIONAL — features degrade gracefully without these)
# -----------------------------------------------------------------------------
# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
VITE_GA4_ID=

# Meta (Facebook) Pixel ID for conversion tracking
VITE_META_PIXEL_ID=

# Meta App ID for Facebook/Instagram OAuth and social features
VITE_META_APP_ID=

# Anthropic API key lives only in Supabase Secrets (ANTHROPIC_API_KEY).
# Never add VITE_ prefix — it would leak the key into the browser bundle.

# -----------------------------------------------------------------------------
# Kiwify Checkout Links (OPTIONAL — payment buttons show "#" if not set)
# Source: Kiwify Dashboard → Products → Checkout Link
# -----------------------------------------------------------------------------
# Main subscription plan
VITE_KIWIFY_PROFISSIONAL_URL=

# Video add-ons
VITE_KIWIFY_ADDON_VIDEOS_FFMPEG_URL=
VITE_KIWIFY_ADDON_VIDEOS_PREMIUM_URL=

# Module add-ons
VITE_KIWIFY_ADDON_WHATSAPP_PRO_URL=
VITE_KIWIFY_ADDON_SOCIAL_AUTOPILOT_URL=
VITE_KIWIFY_ADDON_PORTAIS_XML_URL=
VITE_KIWIFY_ADDON_BUNDLE_URL=

# =============================================================================
# Variables below live INSIDE Supabase Edge Function secrets — NOT here.
# Set via: supabase secrets set KEY=value --project-ref <ref>
# =============================================================================
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# N8N_WEBHOOK_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Evolution API v2 (WhatsApp — self-hosted on Railway)
# Used by n8n workflows for WhatsApp message dispatch.
# Credentials stored in channel_connections table per workspace.
# =============================================================================
# EVOLUTION_API_URL=https://your-evolution-instance.railway.app
# EVOLUTION_API_GLOBAL_KEY=your-global-api-key
